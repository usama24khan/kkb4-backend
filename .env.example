PORT=
MONGODB_URI=
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=
JWT_REFRESH_EXPIRES_IN=
ADMIN_EMAIL=
ADMIN_DEFAULT_PASSWORD=
NODE_ENV=
CORS_ORIGINS=

# ── Cloudinary (media/object storage) ────────────────────────────────────────
# From your Cloudinary dashboard (Account Details / API Keys). PDFs are stored
# as `raw` resources so they're delivered intact.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
# Optional top-level folder to namespace everything under (e.g. "kkb4").
# Leave blank to store at the root (notices/… , receipts/…).
CLOUDINARY_FOLDER=

# ── OTP email (Gmail via nodemailer) ─────────────────────────────────────────
# Gmail address the OTP is sent FROM. Enable 2-Step Verification on the account,
# then create an App Password (Google Account → Security → App passwords) and
# paste the 16-character value (spaces optional) below.
EMAIL_FROM=you@gmail.com
EMAIL_APP_PASSWORD=your-16-char-gmail-app-password
# Inbox the OTP code is delivered TO for unknown-device admin logins. Must be a
# real, deliverable address. Falls back to ADMIN_EMAIL if unset — but ADMIN_EMAIL
# is also the login identity and may not be a real mailbox, so set this.
OTP_EMAIL=you@gmail.com


